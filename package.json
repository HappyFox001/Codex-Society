{
  "name": "codex-society",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A TypeScript SDK for running multi-agent social simulations with pluggable agent runtimes.",
  "bin": {
    "codex-society": "./dist/cli/main.js",
    "society": "./dist/cli/main.js"
  },
  "scripts": {
    "cli": "tsx src/cli/main.ts",
    "dev": "tsx src/examples/run-society.ts",
    "api": "tsx src/api/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./runtime": "./dist/runtime/index.js",
    "./api": "./dist/api/index.js",
    "./project": "./dist/project/index.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
